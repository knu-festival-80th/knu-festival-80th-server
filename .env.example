# Database
DB_URL=jdbc:mysql://localhost:3306/knu_festival?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
DB_USERNAME=festival
DB_PASSWORD=festival
DDL_AUTO=update
JPA_SHOW_SQL=false


# Solapi SMS
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=

# Phone number encryption (둘 다 필수, 32바이트 이상의 랜덤 문자열 권장)
PHONE_ENCRYPTION_KEY=
PHONE_LOOKUP_HASH_KEY=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
SERVER_PORT=8080

# CORS (쉼표 구분, 와일드카드 금지. allowCredentials=true 환경)
# - localhost:3000: 옛 dev 호환
# - localhost:5173: vite dev
# - https://chcse.knu.ac.kr: prod (배포 도메인)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://chcse.knu.ac.kr

# Admin (최고 관리자 마스터 비밀번호, 필수)
ADMIN_MASTER_PASSWORD=

# Gemini AI (포스트잇 내용 검열)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODERATION_PROMPT=

# Profile
SPRING_PROFILES_ACTIVE=local

# ---- Docker Compose only ----
# 컨테이너로 띄울 때 docker-compose.yml 이 사용하는 값들. 로컬 IDE 실행 시에는 무시된다.
MYSQL_DATABASE=knu_festival
MYSQL_USER=festival
MYSQL_PASSWORD=festival
MYSQL_ROOT_PASSWORD=rootpw
