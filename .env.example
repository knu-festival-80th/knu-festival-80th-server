# Database
DB_URL=jdbc:mysql://localhost:3306/knu_festival?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=
DB_PASSWORD=
DDL_AUTO=update
JPA_SHOW_SQL=false

# JWT
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# AWS S3
S3_BUCKET=
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# CDN
CDN_BASE_URL=

# SMS
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_NUMBER=

# Phone number encryption
PHONE_ENCRYPTION_KEY=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
SERVER_PORT=8080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Profile
SPRING_PROFILES_ACTIVE=local

# ---- Docker Compose only ----
# 컨테이너로 띄울 때 docker-compose.yml 이 사용하는 값들. 로컬 IDE 실행 시에는 무시된다.
MYSQL_DATABASE=knu_festival
MYSQL_USER=festival
MYSQL_PASSWORD=festival
MYSQL_ROOT_PASSWORD=rootpw
